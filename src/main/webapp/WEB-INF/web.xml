<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="true">

    <!--
        Rutas MVC (controlador → vista):
          GET|POST /login             → LoginServlet        → WEB-INF/auth/login.jsp
          GET      /                  → welcome-file login  → LoginServlet
          GET|POST /registro           → RegistroServlet     → WEB-INF/auth/registro.jsp
          GET      /logout             → LogoutServlet       → redirect /login
          GET      /estudiante/inicio  → EstudianteInicioServlet → dashboard-estudiante.jsp
          GET      /estudiante/dashboard → EstudianteInicioServlet (alias)
          GET|POST /estudiante/buscar-tutor → BuscarTutorServlet → buscar-tutor.jsp
          GET      /estudiante/tutor/detalle → DetalleTutorEstudianteServlet → detalle-tutor.jsp
          GET      /estudiante/solicitar-mentoria → SolicitarMentoriaServlet → solicitar-mentoria.jsp
          GET      /tutor/inicio       → TutorInicioServlet  → dashboard-tutor.jsp
          GET|POST /tutor/perfil       → PerfilTutorServlet  → perfil-tutor.jsp
          GET      /tutor/horarios     → HorariosTutorServlet    → gestion-horarios-tutor.jsp
          POST     /tutor/horarios/disponibilidad → GestionDisponibilidadServlet
          GET      /tutor/solicitudes  → SolicitudesTutorServlet → bandeja-solicitudes-tutor.jsp
          POST     /tutor/solicitudes/responder → GestionSolicitudServlet → redirect bandeja
          GET      /api/tutores/buscar  → BuscarTutoresServlet   → JSON
          GET      /api/tutores/detalle → DetalleTutorServlet    → JSON
          POST     /api/solicitudes     → CrearSolicitudServlet  → JSON
          GET|POST /tutor/subir         → SubirMaterialServlet   → subir-material.jsp
          GET      /tutor/materiales   → MaterialesTutorServlet → gestiona-material.jsp
          GET      /tutor/materiales/detalle → DetalleMaterialTutorServlet → detalle-material.jsp
          POST     /tutor/materiales/eliminar → EliminarMaterialTutorServlet
          GET      /admin/inicio       → AdminInicioServlet → admin/inicio.jsp
          GET      /admin/materiales   → ModeracionMaterialesServlet → moderacion-materiales.jsp
          POST     /admin/materiales/revisar → RevisarMaterialServlet
          GET      /estudiante/biblioteca → EstudianteBibliotecaServlet → biblioteca-estudiante.jsp
          POST     /estudiante/biblioteca/adquirir → AdquirirMaterialServlet
          GET      /estudiante/biblioteca/descargar → DescargarMaterialServlet
    -->

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>login</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>RegistroServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.RegistroServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegistroServlet</servlet-name>
        <url-pattern>/registro</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.LogoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EstudianteInicioServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.EstudianteInicioServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>EstudianteInicioServlet</servlet-name>
        <url-pattern>/estudiante/inicio</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>EstudianteInicioServlet</servlet-name>
        <url-pattern>/estudiante/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BuscarTutorServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.BuscarTutorServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>BuscarTutorServlet</servlet-name>
        <url-pattern>/estudiante/buscar-tutor</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DetalleTutorEstudianteServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.DetalleTutorEstudianteServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DetalleTutorEstudianteServlet</servlet-name>
        <url-pattern>/estudiante/tutor/detalle</url-pattern>
    </servlet-mapping>

