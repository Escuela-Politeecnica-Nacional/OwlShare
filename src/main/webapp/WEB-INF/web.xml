        <servlet-class>ec.edu.epn.controlador.PerfilTutorServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>PerfilTutorServlet</servlet-name>
        <url-pattern>/tutor/perfil</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HorariosTutorServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.HorariosTutorServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>HorariosTutorServlet</servlet-name>
        <url-pattern>/tutor/horarios</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GestionDisponibilidadServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.GestionDisponibilidadServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>GestionDisponibilidadServlet</servlet-name>
        <url-pattern>/tutor/horarios/disponibilidad</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SolicitudesTutorServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.SolicitudesTutorServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SolicitudesTutorServlet</servlet-name>
        <url-pattern>/tutor/solicitudes</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GestionSolicitudServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.GestionSolicitudServlet</servlet-class>
    </servlet>

    <servlet-mapping>
