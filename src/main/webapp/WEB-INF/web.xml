        <servlet-class>ec.edu.epn.controlador.ModeracionMaterialesServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ModeracionMaterialesServlet</servlet-name>
        <url-pattern>/admin/materiales</url-pattern>
