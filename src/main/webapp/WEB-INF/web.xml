        <servlet-class>ec.edu.epn.controlador.EstudianteBibliotecaServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>EstudianteBibliotecaServlet</servlet-name>
        <url-pattern>/estudiante/biblioteca</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdquirirMaterialServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.AdquirirMaterialServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AdquirirMaterialServlet</servlet-name>
        <url-pattern>/estudiante/biblioteca/adquirir</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DescargarMaterialServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.DescargarMaterialServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DescargarMaterialServlet</servlet-name>
        <url-pattern>/estudiante/biblioteca/descargar</url-pattern>
    </servlet-mapping>

</web-app>
