        <servlet-class>ec.edu.epn.controlador.EliminarMaterialTutorServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>EliminarMaterialTutorServlet</servlet-name>
        <url-pattern>/tutor/materiales/eliminar</url-pattern>
    </servlet-mapping>

    <servlet>
