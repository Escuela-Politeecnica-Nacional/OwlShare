    </servlet-mapping>

    <servlet>
        <servlet-name>CrearSolicitudServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.CrearSolicitudServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>CrearSolicitudServlet</servlet-name>
        <url-pattern>/api/solicitudes</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SubirMaterialServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.SubirMaterialServlet</servlet-class>
        <multipart-config>
            <max-file-size>26214400</max-file-size>
            <max-request-size>27262976</max-request-size>
            <file-size-threshold>1048576</file-size-threshold>
        </multipart-config>
    </servlet>

    <servlet-mapping>
        <servlet-name>SubirMaterialServlet</servlet-name>
        <url-pattern>/tutor/subir</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MaterialesTutorServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.MaterialesTutorServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>MaterialesTutorServlet</servlet-name>
        <url-pattern>/tutor/materiales</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DetalleMaterialTutorServlet</servlet-name>
        <servlet-class>ec.edu.epn.controlador.DetalleMaterialTutorServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DetalleMaterialTutorServlet</servlet-name>
        <url-pattern>/tutor/materiales/detalle</url-pattern>
    </servlet-mapping>

    <servlet>
